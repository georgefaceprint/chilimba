{
  "name": "chilimba-pwa",
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/tracking/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/payments/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/join",
      "destination": "/public/join.html"
    },
    {
      "source": "/flyer",
      "destination": "/public/flyer.html"
    },
    {
      "source": "/policy",
      "destination": "/public/policy.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
